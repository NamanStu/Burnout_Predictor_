# MongoDB Connection Configuration
# Copy this file to .env and update with your values

# ── LOCAL MONGODB (Default) ──────────────────────
# Uncomment to use local MongoDB
# MONGODB_HOST=mongodb://localhost:27017/
# MONGODB_DB_NAME=burnout_db

# ── REMOTE MONGODB (No Authentication) ──────────
# Replace 192.168.1.100 with your remote device's IP
# MONGODB_HOST=mongodb://192.168.1.100:27017/
# MONGODB_DB_NAME=burnout_db

# ── REMOTE MONGODB (With Authentication) ────────
# Replace credentials and IP address with your values
MONGODB_HOST=mongodb://burnout_user:your_secure_password@192.168.1.100:27017/
MONGODB_DB_NAME=burnout_db

# ── MONGODB ATLAS (Cloud) ──────────────────────
# Replace with your Atlas connection string
# MONGODB_HOST=mongodb+srv://burnout_user:your_password@cluster0.xxxxx.mongodb.net/
# MONGODB_DB_NAME=burnout_db

# Connection timeout (milliseconds)
CONNECTION_TIMEOUT=5000
